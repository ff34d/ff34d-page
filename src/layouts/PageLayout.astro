---
import FloatDust from "@/components/FloatDust.astro"
import Footer from "@/components/Footer.astro"
import Header from "@/components/Header.astro"
import "@/styles/index.css"

const TITLE = "Vladimir Volkov (ff34d)"
const DESCRIPTION = "Vladimir Volkov (ff34d) - Frontend-engineer"

const FAVICON_SVG_URL = new URL("favicon.svg", Astro.url).href
const FAVICON_ICO_URL = new URL("favicon.ico", Astro.url).href
const FAVICON_PNG_URL = new URL("favicon-96x96", Astro.url).href
const FAVICON_APPLE_URL = new URL("apple-touch-icon.png", Astro.url).href

const META_IMAGE_URL = new URL("web-app-manifest-512x512.png", Astro.url).href
const META_MANIFEST_URL = new URL("site.webmanifest", Astro.url).href
---

<!doctype html>
<html lang="en">
   <head>
      <!-- Base -->
      <title>{TITLE}</title>
      <meta charset="UTF-8" />
      <meta
         name="viewport"
         content="width=device-width"
      />
      <meta
         name="description"
         content={DESCRIPTION}
      />
      <meta
         name="generator"
         content={Astro.generator}
      />

      <!-- Open Graph -->
      <meta
         property="og:title"
         content={TITLE}
      />
      <meta
         property="og:description"
         content={DESCRIPTION}
      />
      <meta
         property="og:type"
         content="website"
      />
      <meta
         property="og:url"
         content={Astro.url}
      />
      <meta
         property="og:image"
         content={META_IMAGE_URL}
      />
      <meta
         property="og:image:width"
         content="512"
      />
      <meta
         property="og:image:height"
         content="512"
      />

      <!-- Twitter -->
      <meta
         name="twitter:card"
         content="summary"
      />
      <meta
         name="twitter:title"
         content={TITLE}
      />
      <meta
         name="twitter:description"
         content={DESCRIPTION}
      />
      <meta
         name="twitter:image"
         content={META_IMAGE_URL}
      />

      <!-- Links -->
      <link
         rel="icon"
         type="image/png"
         href={FAVICON_PNG_URL}
         sizes="96x96"
      />
      <link
         rel="icon"
         type="image/svg+xml"
         href={FAVICON_SVG_URL}
      />
      <link
         rel="shortcut icon"
         href={FAVICON_ICO_URL}
      />
      <link
         rel="apple-touch-icon"
         sizes="180x180"
         href={FAVICON_APPLE_URL}
      />
      <meta
         name="apple-mobile-web-app-title"
         content="VV (ff34d)"
      />
      <link
         rel="manifest"
         href={META_MANIFEST_URL}
      />
      <link
         rel="canonical"
         href={Astro.url}
      />

      <!-- Scheme ld -->
      <script
         type="application/ld+json"
         set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Blog",
            name: TITLE,
            description: DESCRIPTION,
            image: META_IMAGE_URL,
            url: Astro.url.toString(),
            publisher: {
               "@type": "Person",
               name: "Vladimir Volkov",
               url: "https://ff34d.github.io/ff34d-page/",
               image: {
                  "@type": "ImageObject",
                  url: META_IMAGE_URL,
                  width: "500",
                  height: "500",
               },
               sameAs: ["https://github.com/ff34d"],
            },
         })}
      />

      <!-- Initialize theme -->
      <script is:inline>
         ;(function () {
            const stored = localStorage.getItem("_theme")
            const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
            const theme = stored || (prefersDark ? "dark" : "light")
            document.documentElement.classList.add(theme)
         })()
      </script>
   </head>

   <body class="glow">
      <FloatDust />

      <Header />

      <main class="box content">
         <slot />
      </main>

      <Footer />
   </body>
</html>
